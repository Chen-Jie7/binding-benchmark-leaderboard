# 1. Create a Google Cloud service account with Sheets API enabled
# 2. Download the JSON key file
# 3. Copy this file to secrets.toml and fill in the values from the JSON key
# 4. Create a Google Sheet and share it with the service account email (Editor access)
# 5. On Streamlit Cloud: paste these secrets in Settings > Secrets

sheet_name = "binding-benchmark-leaderboard"

[gcp_service_account]
type = "service_account"
project_id = ""
private_key_id = ""
private_key = ""
client_email = ""
client_id = ""
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = ""
